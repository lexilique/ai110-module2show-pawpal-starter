classDiagram
    class Owner {
        +str name
        +list~Pet~ pets
        +int time_availability
        +add_pet(pet) None
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +list~DailyTasks~ tasks
        +add_task(task) None
        +edit_task(index, changes) None
        +remove_task(index) None
    }

    class DailyTasks {
        +str name
        +Pet pet
        +str task_type
        +int duration_mins
        +str priority
        +str time_start
        +str frequency
        +date due_date
        +bool is_completed
        +priority_level() int
        +next_occurrence() DailyTasks
        +mark_complete() DailyTasks
        +describe() str
    }

    class Scheduler {
        +Owner owner
        +list plan
        +list~DailyTasks~ skipped
        +all_tasks() list~DailyTasks~
        +filter_by_completion(completed) list~DailyTasks~
        +priority_sort(tasks) list~DailyTasks~
        +sort_by_time(tasks) list~DailyTasks~
        +generate_plan() list
        +detect_conflicts() str
        +explain() str
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" <--> "*" DailyTasks : has / belongs to
    Scheduler --> Owner : reads
    Scheduler ..> DailyTasks : schedules
    DailyTasks ..> Pet : re-adds recurring task
    DailyTasks ..> DailyTasks : spawns next occurrence
